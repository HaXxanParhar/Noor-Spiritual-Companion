<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_row_height"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_home_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md">

        <TextView
            android:layout_width="@dimen/icon_box_size"
            android:layout_height="@dimen/icon_box_size"
            android:background="@drawable/bg_icon_box_teal"
            android:gravity="center"
            android:text="📖" />

        <TextView
            style="@style/TextAppearance.App.BodyPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:text="Quran reading"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_check_circle"
            android:gravity="center"
            android:text="@string/status_done"
            android:textColor="@color/navy_base"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_row_height"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_home_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md">

        <TextView
            android:layout_width="@dimen/icon_box_size"
            android:layout_height="@dimen/icon_box_size"
            android:background="@drawable/bg_icon_box_teal"
            android:gravity="center"
            android:text="📚" />

        <TextView
            style="@style/TextAppearance.App.BodyPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:text="Translation / Tafseer"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="42dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_points_chip"
            android:gravity="center"
            android:text="@string/points_one"
            android:textStyle="bold" />

        <TextView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_empty_circle" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_row_height"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_home_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md">

        <TextView
            android:layout_width="@dimen/icon_box_size"
            android:layout_height="@dimen/icon_box_size"
            android:background="@drawable/bg_icon_box_teal"
            android:gravity="center"
            android:text="📜" />

        <TextView
            style="@style/TextAppearance.App.BodyPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:text="Hadith"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="42dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_points_chip"
            android:gravity="center"
            android:text="@string/points_one"
            android:textStyle="bold" />

        <TextView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_empty_circle" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_row_height"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_home_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md">

        <TextView
            android:layout_width="@dimen/icon_box_size"
            android:layout_height="@dimen/icon_box_size"
            android:background="@drawable/bg_icon_box_warm"
            android:gravity="center"
            android:text="🤲" />

        <TextView
            style="@style/TextAppearance.App.BodyPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:text="Daily supplication"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="42dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_points_chip"
            android:gravity="center"
            android:text="@string/points_one"
            android:textStyle="bold" />

        <TextView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_empty_circle" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_row_height"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_home_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md">

        <TextView
            android:layout_width="@dimen/icon_box_size"
            android:layout_height="@dimen/icon_box_size"
            android:background="@drawable/bg_icon_box"
            android:gravity="center"
            android:text="💜" />

        <TextView
            style="@style/TextAppearance.App.BodyPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:text="Darood"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="42dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_points_chip"
            android:gravity="center"
            android:text="@string/points_one"
            android:textStyle="bold" />

        <TextView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_empty_circle" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/home_row_height"
        android:layout_marginTop="@dimen/spacing_sm"
        android:background="@drawable/bg_home_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md">

        <TextView
            android:layout_width="@dimen/icon_box_size"
            android:layout_height="@dimen/icon_box_size"
            android:background="@drawable/bg_icon_box_warm"
            android:gravity="center"
            android:text="🌙" />

        <TextView
            style="@style/TextAppearance.App.BodyPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:text="Tahajjud"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="42dp"
            android:layout_height="30dp"
            android:background="@drawable/bg_points_chip"
            android:gravity="center"
            android:text="@string/points_two"
            android:textStyle="bold" />

        <TextView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_empty_circle" />
    </LinearLayout>
</LinearLayout>
