<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true"
    android:paddingTop="40dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <TextView
            style="@style/TextAppearance.App.Display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Create Account" />

        <TextView
            style="@style/TextAppearance.App.BodyPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center"
            android:text="This name will be shown on the leaderboard. You can choose an anonymous name or your real name." />

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="DISPLAY NAME"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/nameEditText"
            style="@style/TextAppearance.App.Input"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_input"
            android:hint="Enter your name"
            android:inputType="textCapWords"
            android:textColorHint="@color/text_muted" />

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="GENDER"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/maleTextView"
                style="@style/TextAppearance.App.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_action"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Male"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/femaleTextView"
                style="@style/TextAppearance.App.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_secondary_action"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Female"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusTextView"
            style="@style/TextAppearance.App.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center" />

        <TextView
            android:id="@+id/createAccountTextView"
            style="@style/TextAppearance.App.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_xl"
            android:background="@drawable/bg_primary_action"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Create Account" />
    </LinearLayout>
</ScrollView>
