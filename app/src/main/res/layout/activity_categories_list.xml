<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/spacing_lg"
    android:paddingTop="40dp"
    android:paddingBottom="@dimen/spacing_2xl">

    <include
        android:id="@+id/toolbar"
        layout="@layout/layout_activity_toolbar" />

    <LinearLayout
        android:id="@+id/selectionActionBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="@dimen/spacing_md"
        android:background="@drawable/bg_home_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/spacing_md"
        android:visibility="gone">

        <TextView
            android:id="@+id/closeSelectionTextView"
            style="@style/TextAppearance.App.BodyPrimary"
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:padding="@dimen/spacing_sm"
            android:text="@string/admin_close_selection"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/deleteCategoryTextView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="20dp"
            android:clickable="true"
            android:contentDescription="@string/admin_delete_category_action"
            android:focusable="true"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_trash" />

        <ImageView
            android:id="@+id/moveUpTextView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:contentDescription="@string/admin_move_up"
            android:focusable="true"
            android:padding="@dimen/spacing_sm"
            android:rotation="180"
            android:src="@drawable/ic_move_up"
            android:tint="@color/white" />

        <ImageView
            android:id="@+id/moveDownTextView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:contentDescription="@string/admin_move_down"
            android:focusable="true"
            android:padding="@dimen/spacing_sm"
            android:src="@drawable/ic_move_up"
            android:tint="@color/white" />

    </LinearLayout>

    <TextView
        android:id="@+id/addCategoryTextView"
        style="@style/TextAppearance.App.Button"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="@drawable/bg_primary_action"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="@string/admin_add_category_action" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/categoriesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_lg" />

    <TextView
        android:id="@+id/emptyTextView"
        style="@style/TextAppearance.App.Caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/admin_categories_empty"
        android:visibility="gone" />

</LinearLayout>
