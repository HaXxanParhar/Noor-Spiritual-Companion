<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/friendRow"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/spacing_sm"
    android:background="@drawable/bg_home_row"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minHeight="@dimen/home_row_height"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/spacing_lg"
    android:paddingVertical="@dimen/spacing_sm">

    <TextView
        android:id="@+id/avatarTextView"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/nameTextView"
        style="@style/TextAppearance.App.BodyPrimary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_weight="1"
        android:textColor="@color/text_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/remindTextView"
        style="@style/TextAppearance.App.CaptionSmall"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:background="@drawable/bg_secondary_action"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="72dp"
        android:paddingHorizontal="@dimen/spacing_sm"
        android:text="@string/friends_remind"
        android:textColor="@color/gold_primary"
        android:textStyle="bold" />

    <TextView
        style="@style/TextAppearance.App.Caption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_sm"
        android:text="›"
        android:textColor="@color/text_muted" />
</LinearLayout>
