<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextAppearance.App.BodySecondary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_greeting" />

                    <TextView
                        android:id="@+id/userNameTextView"
                        style="@style/TextAppearance.App.Display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_user_name" />

                    <TextView
                        android:id="@+id/dateTextView"
                        style="@style/TextAppearance.App.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_date" />
                </LinearLayout>

                <TextView
                    android:id="@+id/avatar"
                    style="@style/TextAppearance.App.Caption"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_leaderboard_avatar_default"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/streakContainer"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="@dimen/spacing_xl"
                android:background="@drawable/bg_home_streak_disabled"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/streakLabelTextView"
                        style="@style/TextAppearance.App.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_streak_label"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/streakCountTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins"
                        android:text="0"
                        android:textColor="@color/text_muted"
                        android:textSize="42sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/streakDaysTextView"
                        style="@style/TextAppearance.App.BodyPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_streak_days"
                        android:textColor="@color/text_muted"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/streakHintTextView"
                        style="@style/TextAppearance.App.Caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/home_streak_hint_empty"
                        android:textColor="@color/text_muted" />
                </LinearLayout>

                <TextView
                    android:id="@+id/streakFireTextView"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:alpha="0.35"
                    android:gravity="center"
                    android:text="🔥"
                    android:textSize="44sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:layout_marginTop="@dimen/spacing_md"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/todayPointsTextView"
                    style="@style/TextAppearance.App.Caption"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_home_card"
                    android:gravity="center"
                    android:text="8\nToday"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/weeklyPointsTextView"
                    style="@style/TextAppearance.App.Caption"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_home_card"
                    android:gravity="center"
                    android:text="0\nThis week"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/allTimePointsTextView"
                    style="@style/TextAppearance.App.Caption"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_home_card"
                    android:gravity="center"
                    android:text="0\nAll time"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tasksStatusTextView"
                style="@style/TextAppearance.App.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:gravity="center"
                android:text="Loading tasks..." />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tasksContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />
        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/pointsInfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:alpha="1"
        android:background="@drawable/bg_points_info"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_lg"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvEmoji"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_quote_card"
            android:gravity="center"
            android:text="👏"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/pointsInfoTextView"
            style="@style/TextAppearance.App.BodyPrimary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />
    </LinearLayout>

</RelativeLayout>
