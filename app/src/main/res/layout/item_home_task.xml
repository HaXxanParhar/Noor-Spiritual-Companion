<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/taskRow"
    android:layout_width="match_parent"
    android:layout_height="@dimen/home_row_height"
    android:layout_marginTop="@dimen/spacing_sm"
    android:background="@drawable/bg_home_row"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/spacing_md">

    <TextView
        android:id="@+id/iconTextView"
        android:layout_width="@dimen/icon_box_size"
        android:layout_height="@dimen/icon_box_size"
        android:background="@drawable/bg_icon_box"
        android:gravity="center" />

    <TextView
        android:id="@+id/taskNameTextView"
        style="@style/TextAppearance.App.BodyPrimary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_weight="1"
        android:textColor="@color/text_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/pointsTextView"
        style="@style/TextAppearance.App.CaptionSmall"
        android:layout_width="42dp"
        android:layout_height="30dp"
        android:background="@drawable/bg_points_chip"
        android:gravity="center"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginStart="@dimen/spacing_sm"
        android:gravity="center" />
</LinearLayout>
