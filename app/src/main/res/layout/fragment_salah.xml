<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <TextView
            style="@style/TextAppearance.App.Heading1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/salah_title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_home_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <TextView
                style="@style/TextAppearance.App.CaptionSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.12"
                android:text="⏰ NEXT PRAYER"
                android:textColor="@color/teal_quran_salah"
                android:textStyle="bold" />

            <TextView
                style="@style/TextAppearance.App.Display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zuhr" />

            <TextView
                style="@style/TextAppearance.App.Arabic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الظهر"
                android:textColor="@color/teal_quran_salah" />

            <TextView
                style="@style/TextAppearance.App.Heading2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:48 PM" />

            <TextView
                style="@style/TextAppearance.App.Caption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="in 3h 07m · Islamabad" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/prayerRowsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:orientation="vertical">

            <include layout="@layout/view_salah_rows" />
        </LinearLayout>

        <TextView
            style="@style/TextAppearance.App.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center"
            android:text="Hanafi method · tap ⚙ to change" />
    </LinearLayout>
</ScrollView>
