<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/spacing_lg"
    android:paddingTop="40dp"
    android:paddingBottom="10dp">

    <include
        android:id="@+id/toolbar"
        layout="@layout/layout_activity_toolbar" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xl"
        android:background="@drawable/bg_home_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xl">

        <TextView
            style="@style/TextAppearance.App.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/invite_your_user_id" />

        <TextView
            android:id="@+id/userIdTextView"
            style="@style/TextAppearance.App.BodyPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_secondary_action"
            android:gravity="center"
            android:minHeight="56dp"
            android:padding="@dimen/spacing_md"
            android:textColor="@color/gold_primary"
            android:textStyle="bold" />

        <TextView
            style="@style/TextAppearance.App.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center"
            android:text="@string/invite_copy_hint" />

        <TextView
            android:id="@+id/copyUserIdTextView"
            style="@style/TextAppearance.App.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_primary_action"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/action_copy" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="@drawable/bg_home_card"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/invite_enter_friend_id"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/friendIdEditText"
            style="@style/TextAppearance.App.Input"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_input"
            android:hint="@string/invite_friend_id_hint"
            android:importantForAutofill="no"
            android:inputType="text"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted" />

        <TextView
            android:id="@+id/addFriendTextView"
            style="@style/TextAppearance.App.Button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="end"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_primary_action"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="96dp"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:text="@string/action_add_friend" />

        <TextView
            android:id="@+id/statusTextView"
            style="@style/TextAppearance.App.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:textColor="@color/text_muted" />
    </LinearLayout>
</LinearLayout>
