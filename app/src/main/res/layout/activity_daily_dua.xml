<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:paddingHorizontal="@dimen/spacing_lg"
    android:paddingTop="40dp"
    android:paddingBottom="@dimen/spacing_2xl"
    android:fillViewport="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <include
            android:id="@+id/toolbar"
            layout="@layout/layout_activity_toolbar" />
        <TextView style="@style/TextAppearance.App.Button" android:layout_width="match_parent" android:layout_height="40dp" android:layout_marginTop="@dimen/spacing_lg" android:gravity="center_vertical" android:text="🌅 Morning      🌃 Evening      🌙 Night" android:textColor="@color/rose_dua" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_lg" android:background="@drawable/bg_home_card" android:orientation="vertical" android:padding="@dimen/spacing_lg">
            <TextView style="@style/TextAppearance.App.CaptionSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_points_chip" android:padding="@dimen/spacing_sm" android:text="Upon waking" android:textColor="@color/rose_dua" android:textStyle="bold" />
            <TextView style="@style/TextAppearance.App.Arabic" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md" android:gravity="end" android:text="الْحَمْدُ لِلَّهِ الَّذِي أَحْيَانَا بَعْدَ مَا أَمَاتَنَا" />
            <TextView style="@style/TextAppearance.App.Caption" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md" android:text="Alhamdu lillahil-lathi ahyana ba'da ma amatana" android:textStyle="italic" />
            <TextView style="@style/TextAppearance.App.BodyPrimary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md" android:text="Praise be to Allah who gave us life after having taken it from us." />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md" android:background="@drawable/bg_home_card" android:orientation="vertical" android:padding="@dimen/spacing_lg">
            <TextView style="@style/TextAppearance.App.CaptionSmall" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_points_chip" android:padding="@dimen/spacing_sm" android:text="Morning protection" android:textColor="@color/teal_quran_salah" android:textStyle="bold" />
            <TextView style="@style/TextAppearance.App.Arabic" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md" android:gravity="end" android:text="اللَّهُمَّ بِكَ أَصْبَحْنَا وَبِكَ أَمْسَيْنَا" />
            <TextView style="@style/TextAppearance.App.Caption" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md" android:text="Allahumma bika asbahna wa bika amsayna" android:textStyle="italic" />
            <TextView style="@style/TextAppearance.App.BodyPrimary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/spacing_md" android:text="O Allah, by You we enter the morning and by You we enter the evening." />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
