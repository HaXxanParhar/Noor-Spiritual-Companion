<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingTop="40dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/spacing_lg">

            <include
                android:id="@+id/toolbar"
                layout="@layout/layout_activity_toolbar" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/userAvatarTextView"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:textColor="@color/gold_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/userNameTextView"
                    style="@style/TextAppearance.App.Display"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/viewProfileTextView"
                    style="@style/TextAppearance.App.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_secondary_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:paddingVertical="@dimen/spacing_xs"
                    android:text="@string/user_tasks_view_profile"
                    android:textColor="@color/gold_primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:layout_marginTop="@dimen/spacing_lg"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/streakStatTextView"
                    style="@style/TextAppearance.App.Caption"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_home_card"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/allTimeStatTextView"
                    style="@style/TextAppearance.App.Caption"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:layout_weight="1"
                    android:background="@drawable/bg_home_card"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/weeklyStatTextView"
                    style="@style/TextAppearance.App.Caption"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_home_card"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />
            </LinearLayout>

            <include
                android:id="@+id/dateNavigator"
                layout="@layout/layout_date_navigator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:visibility="gone" />

            <TextView
                android:id="@+id/privateTasksMessageTextView"
                style="@style/TextAppearance.App.BodyPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:background="@drawable/bg_home_row"
                android:gravity="center"
                android:minHeight="120dp"
                android:padding="@dimen/spacing_lg"
                android:text="@string/user_tasks_private_message"
                android:textColor="@color/text_muted"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tasksStatusTextView"
                style="@style/TextAppearance.App.Caption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:gravity="center"
                android:text="@string/home_tasks_loading"
                android:visibility="gone" />

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/tasksShimmerContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:visibility="gone"
                app:shimmer_auto_start="false"
                app:shimmer_base_alpha="1"
                app:shimmer_base_color="@color/shimmer_base"
                app:shimmer_duration="1100"
                app:shimmer_highlight_alpha="0.55"
                app:shimmer_highlight_color="@color/shimmer_highlight">

                <include layout="@layout/layout_home_tasks_shimmer" />
            </com.facebook.shimmer.ShimmerFrameLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tasksContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>
