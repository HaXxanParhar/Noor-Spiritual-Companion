<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/spacing_xl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dialog"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingTop="28dp"
        android:paddingBottom="@dimen/spacing_xl">

        <TextView
            android:id="@+id/iconTextView"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_quote_card"
            android:gravity="center"
            android:text="🔔"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/titleTextView"
            style="@style/TextAppearance.App.Heading1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:gravity="center"
            android:textColor="@color/gold_primary" />

        <TextView
            android:id="@+id/messageTextView"
            style="@style/TextAppearance.App.BodyPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/text_secondary" />

        <EditText
            android:id="@+id/reminderMessageEditText"
            style="@style/TextAppearance.App.Input"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_input"
            android:gravity="top|start"
            android:importantForAutofill="no"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLength="@integer/reminder_message_max_length"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_md"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted" />

        <TextView
            android:id="@+id/charCountTextView"
            style="@style/TextAppearance.App.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:gravity="end"
            android:textColor="@color/text_muted"
            tools:text="0/200" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/negativeButton"
                style="@style/TextAppearance.App.Button"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_dialog_negative_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/action_cancel"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/positiveButton"
                style="@style/TextAppearance.App.Button"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_weight="1"
                android:background="@drawable/bg_primary_action"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/action_send" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
