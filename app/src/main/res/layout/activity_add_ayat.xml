<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true"
    android:paddingHorizontal="@dimen/spacing_lg"
    android:paddingTop="40dp"
    android:paddingBottom="@dimen/spacing_2xl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include
            android:id="@+id/toolbar"
            layout="@layout/layout_activity_toolbar" />

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:text="@string/admin_ayat_arabic_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/ayatArabicEditText"
            style="@style/TextAppearance.App.Inputy.Arabic"
            android:layout_width="match_parent"
            android:layout_height="@dimen/admin_multiline_input_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_input"
            android:fontFamily="@font/amiri"
            android:hint="@string/admin_ayat_arabic_hint"
            android:imeOptions="flagNoEnterAction"
            android:inputType="textMultiLine"
            android:minLines="5"
            android:overScrollMode="always"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_md"
            android:scrollbars="vertical"
            android:textColorHint="@color/text_muted"
            />

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/admin_ayat_urdu_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/ayatUrduEditText"
            style="@style/TextAppearance.App.Inputy.Urdu"
            android:layout_width="match_parent"
            android:layout_height="@dimen/admin_multiline_input_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_input"
            android:fontFamily="@font/noto_nastaliq_regular"
            android:hint="@string/admin_ayat_urdu_hint"
            android:imeOptions="flagNoEnterAction"
            android:inputType="textMultiLine"
            android:minLines="5"
            android:overScrollMode="always"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_md"
            android:scrollbars="vertical"
            android:textColorHint="@color/text_muted"
            />

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/admin_ayat_english_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/ayatEnglishEditText"
            style="@style/TextAppearance.App.Input"
            android:layout_width="match_parent"
            android:layout_height="@dimen/admin_multiline_input_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_input"
            android:gravity="top|start"
            android:hint="@string/admin_ayat_english_hint"
            android:imeOptions="flagNoEnterAction"
            android:inputType="textCapSentences|textMultiLine"
            android:minLines="5"
            android:overScrollMode="always"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_md"
            android:scrollbars="vertical"
            android:textColorHint="@color/text_muted" />

        <TextView
            style="@style/TextAppearance.App.CaptionSmall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/admin_ayat_reference_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/ayatReferenceEditText"
            style="@style/TextAppearance.App.Input"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_input"
            android:hint="@string/admin_ayat_reference_hint"
            android:inputType="textCapSentences"
            android:textColorHint="@color/text_muted" />

        <TextView
            android:id="@+id/statusTextView"
            style="@style/TextAppearance.App.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:textColor="@color/text_muted" />

        <TextView
            android:id="@+id/saveAyatTextView"
            style="@style/TextAppearance.App.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_xl"
            android:background="@drawable/bg_primary_action"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/admin_add_ayat_action" />

        <TextView
            android:id="@+id/deleteAyatTextView"
            style="@style/TextAppearance.App.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_logout_action"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/admin_delete_ayat_action"
            android:textColor="@color/rose_dua"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
